# ═══════════════════════════════════════════════════════════
# AI-Medikelizar — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your keys.
# The app's js/config.js also accepts these values directly.
# ═══════════════════════════════════════════════════════════

# ── PubMed API (required for source retrieval) ──
PUBMED_API_KEY=your_ncbi_api_key
PUBMED_EMAIL=your_email@example.com    # NCBI requires a valid contact email

# ── AI Provider: Choose ONE group below ──

# Option A — OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Option B — Ollama (local, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Option C — Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Option D — Google Gemini
GOOGLE_API_KEY=your-google-api-key
GOOGLE_MODEL=gemini-1.5-flash

# Option E — Custom OpenAI-compatible endpoint
CUSTOM_API_KEY=
CUSTOM_ENDPOINT=
CUSTOM_MODEL=

# ── Optional: source-specific API keys ──
CDC_API_KEY=your_cdc_api_key
WHO_API_KEY=your_who_api_key
