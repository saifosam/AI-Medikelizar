# ═══════════════════════════════════════════════════════════════
# AI-Medikelizar — Environment Configuration
# ═══════════════════════════════════════════════════════════════
#
# 👉 THIS IS THE ONLY FILE you need to edit to change the AI provider
#    and model. Copy this file to .env and fill in your settings.
#
#    cp .env.example .env
#
# All provider and model configuration lives here — NOT in app.py,
# NOT in config.js. One file, one place.
#
# ═══════════════════════════════════════════════════════════════


# ══════════════════════════════════════════════════════════
# Active Provider
# ══════════════════════════════════════════════════════════
# Choose one: "google" | "openrouter" | "ollama"
#   google     — Google Gemini API (requires GOOGLE_API_KEY)
#   openrouter — OpenRouter (requires OPENROUTER_API_KEY)
#   ollama     — Local Ollama (no API key needed)
AI_PROVIDER=ollama

# ══════════════════════════════════════════════════════════
# Google Gemini
# ══════════════════════════════════════════════════════════
# Get your API key at: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=your_api_key_here
# GOOGLE_MODEL=gemini-2.0-flash-lite

# ══════════════════════════════════════════════════════════
# OpenRouter (OpenAI-compatible proxy)
# ══════════════════════════════════════════════════════════
# Get your API key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=your_api_key_here
# OPENROUTER_MODEL=gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ══════════════════════════════════════════════════════════
# Ollama (local)
# ══════════════════════════════════════════════════════════
# Make sure Ollama is running:  ollama serve
# OLLAMA_MODEL=qwen2.5-coder:7b
# OLLAMA_BASE_URL=http://localhost:11434

# ══════════════════════════════════════════════════════════
# Legacy Providers (support for openai, anthropic, custom)
# ══════════════════════════════════════════════════════════
# These are also supported if you set AI_PROVIDER to one of:
#   "openai"     — Requires OPENAI_API_KEY
#   "anthropic"  — Requires ANTHROPIC_API_KEY
#   "custom"     — Requires CUSTOM_ENDPOINT
#
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_ENDPOINT=https://api.openai.com/v1
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-haiku-20240307
# CUSTOM_API_KEY=
# CUSTOM_ENDPOINT=
# CUSTOM_MODEL=

# ══════════════════════════════════════════════════════════
# PubMed E-utilities
# ══════════════════════════════════════════════════════════
# PUBMED_API_KEY=
# PUBMED_EMAIL=user@example.com
# PUBMED_TOOL=AI-Medikelizar

# ══════════════════════════════════════════════════════════
# Retrieval Settings
# ══════════════════════════════════════════════════════════
# DEFAULT_CONFIDENCE=medium
# MAX_SOURCES=8
# MIN_RELEVANCE=0.7
# CACHE_RESULTS=True

# ══════════════════════════════════════════════════════════
# Stripe (subscriptions)
# ══════════════════════════════════════════════════════════
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PREMIUM_PRICE_ID=
# STRIPE_VIP_PRICE_ID=

# ══════════════════════════════════════════════════════════
# Clerk (authentication)
# ══════════════════════════════════════════════════════════
# CLERK_WEBHOOK_SECRET=
# CLERK_SECRET_KEY=

# ══════════════════════════════════════════════════════════
# Admin
# ══════════════════════════════════════════════════════════
# ADMIN_EMAILS=admin@ai-medikelizar.com

# ══════════════════════════════════════════════════════════
# Rate Limiting
# ══════════════════════════════════════════════════════════
# RATE_LIMIT_ENABLED=true
# LOGIN_RATE_LIMIT=10/minute

# ══════════════════════════════════════════════════════════
# System Prompt
# ══════════════════════════════════════════════════════════
# SYSTEM_PROMPT=You are a clinical reference assistant...
