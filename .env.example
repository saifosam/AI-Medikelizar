# ═══════════════════════════════════════════════════════════
#  AI-Medikelizar — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and edit it:
#   cp .env.example .env
#
# The AI provider and model are controlled here.
# See each section below for setup instructions.
#
# 🆓 FREE PROVIDERS (no credit card needed):
#   - Google Gemini:  aistudio.google.com/apikey
#   - Groq:           console.groq.com
#   - Ollama (local): ollama.ai
# ═══════════════════════════════════════════════════════════


# ── Active AI Provider ────────────────────────────────────
# Options: ollama (local), google (free), groq (free),
#          openai, anthropic, openrouter, custom
#
# ⚠️  If you set AI_PROVIDER=google or groq below, you MUST
#    also set the corresponding API key (GOOGLE_API_KEY or
#    GROQ_API_KEY) or the app will fail on startup!
#
#    Get your free Google key: https://aistudio.google.com/apikey
#    Get your free Groq key:   https://console.groq.com
AI_PROVIDER=google


# ── Google Gemini (🆓 FREE — no credit card) ──────────────
# Get a free API key: https://aistudio.google.com/apikey
# Google's free tier is very generous (~15 RPM).
# Models: gemini-2.0-flash-lite, gemini-2.0-flash, gemini-2.5-pro
#GOOGLE_API_KEY=AIza...
#GOOGLE_MODEL=gemini-2.0-flash-lite


# ── Groq (🆓 FREE — no credit card) ───────────────────────
# Get a free API key: https://console.groq.com
# Fast inference, OpenAI-compatible. ~30 RPM, 14,400 RPD free.
# Models: llama-3.1-8b-instant, llama-3.3-70b-versatile, mixtral-8x7b-32768
#GROQ_API_KEY=gsk_...
#GROQ_MODEL=llama-3.1-8b-instant
#GROQ_BASE_URL=https://api.groq.com/openai/v1


# ── Ollama (🆓 FREE — local, no key needed) ───────────────
# Runs locally. Install from https://ollama.ai
# Then: ollama pull qwen2.5-coder:7b
#OLLAMA_MODEL=qwen2.5-coder:7b
#OLLAMA_BASE_URL=http://localhost:11434


# ── OpenRouter (free models available) ────────────────────
# Get a key: https://openrouter.ai/keys
# Free models list: https://openrouter.ai/collections/free-models
#OPENROUTER_API_KEY=sk-or-...
#OPENROUTER_MODEL=gpt-4o-mini
#OPENROUTER_BASE_URL=https://openrouter.ai/api/v1


# ── OpenAI (paid) ─────────────────────────────────────────
#OPENAI_API_KEY=sk-...
#OPENAI_MODEL=gpt-4o-mini
#OPENAI_ENDPOINT=https://api.openai.com/v1


# ── Anthropic (paid) ──────────────────────────────────────
#ANTHROPIC_API_KEY=sk-ant-...
#ANTHROPIC_MODEL=claude-3-haiku-20240307


# ── Custom (OpenAI-compatible endpoint) ───────────────────
# Use this for any OpenAI-compatible API (e.g. Together AI, DeepSeek, etc.)
#CUSTOM_API_KEY=...
#CUSTOM_ENDPOINT=...
#CUSTOM_MODEL=...


# ── PubMed E-utilities (🆓 FREE) ─────────────────────────
# Get a free API key: https://www.ncbi.nlm.nih.gov/account/
#   → Account Settings → API Key Management → Create an API Key
# With key: 10 req/s. Without key: 3 req/s.
#PUBMED_API_KEY=...
#PUBMED_EMAIL=user@example.com
#PUBMED_TOOL=AI-Medikelizar


# ── Retrieval Settings ────────────────────────────────────
#DEFAULT_CONFIDENCE=medium    # low | medium | high
#MAX_SOURCES=8
#MIN_RELEVANCE=0.7
#CACHE_RESULTS=true


# ── Stripe (optional, for subscriptions) ─────────────────
#STRIPE_SECRET_KEY=sk_...
#STRIPE_PUBLISHABLE_KEY=pk_...
#STRIPE_WEBHOOK_SECRET=whsec_...
#STRIPE_PREMIUM_PRICE_ID=price_...
#STRIPE_VIP_PRICE_ID=price_...


# ── Clerk (optional, for authentication) ─────────────────
#CLERK_SECRET_KEY=sk_...
#CLERK_WEBHOOK_SECRET=whsec_...


# ── Admin ─────────────────────────────────────────────────
# Comma-separated list of admin email addresses
#ADMIN_EMAILS=admin@example.com,saifosam.business@gmail.com,yassinadeleid95@gmail.com,youssef.shabayek56@gmail.com,yjhf04508@gmail.com


# ── Rate Limiting ─────────────────────────────────────────
#RATE_LIMIT_ENABLED=true
#LOGIN_RATE_LIMIT=10/minute


# ── System Prompt ─────────────────────────────────────────
#SYSTEM_PROMPT=You are...
